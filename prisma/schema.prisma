generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  secondmeUserId    String?   @unique @map("secondme_user_id")
  accessToken       String?   @map("access_token")
  refreshToken      String?   @map("refresh_token")
  tokenExpiresAt    DateTime? @map("token_expires_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  email             String?   @unique
  passwordHash      String?   @map("password_hash")
  authProvider      String    @default("secondme") @map("auth_provider")
  name              String?
  avatarUrl         String?   @map("avatar_url")
  bio               String?
  // 双向心动筛选：male | female | nonbinary 等；未填则不做性别向匹配
  gender            String?   @map("gender")
  // 双向年龄期望；未填则仅依据偏好区间重叠规则
  age               Int?      @map("age")
  latitude          Float?    @map("latitude")
  longitude         Float?    @map("longitude")
  locationUpdatedAt DateTime? @map("location_updated_at")

  photo1                 String?   @map("photo_1")
  photo2                 String?   @map("photo_2")
  photo3                 String?   @map("photo_3")
  onboardingDone         Boolean   @default(true) @map("onboarding_done")
  privacyAcceptedAt      DateTime? @map("privacy_accepted_at")
  agentLearnConsent      Boolean   @default(false) @map("agent_learn_consent")
  resetPasswordTokenHash String?   @map("reset_password_token_hash")
  resetPasswordExpiresAt DateTime? @map("reset_password_expires_at")
  shortId                String?   @unique @map("short_id")
  profileAnswers         Json?     @map("profile_answers")
  profileCompleteness    Int       @default(0) @map("profile_completeness")  // 0-100%
  dailyStreak            Int       @default(0) @map("daily_streak")          // 连续签到天数
  lastCheckIn            DateTime? @map("last_check_in")                     // 上次签到时间
  popularityScore        Int       @default(0) @map("popularity_score")       // 受欢迎度
  viewCount              Int       @default(0) @map("view_count")            // 被查看次数

  sessions               Session[]
  ownerFacts             OwnerFact[]
  preference             UserPreference?
  matchesAsUser          Match[]             @relation("UserMatches")
  matchesAsTarget        Match[]             @relation("TargetUserMatches")
  feedbacksGiven         MatchFeedback[]
  matchReads             MatchRead[]         @relation("MatchReadUser")
  swipeDecisionsGiven    UserSwipeDecision[] @relation("SwipeDecisionViewer")
  swipeDecisionsReceived UserSwipeDecision[] @relation("SwipeDecisionTarget")

  townPosts                    TownPost[]
  townCandidateRounds          TownCandidateRound[]
  townConversationsAsRequester TownConversation[]        @relation("TownRequester")
  townConversationsAsCandidate TownConversation[]        @relation("TownCandidate")
  townConversationReads        TownConversationRead[]    @relation("TownConversationReadsUser")
  townConversationMessages     TownConversationMessage[] @relation("TownConversationMessageSender")
  townPostLikes                TownPostLike[]
  townPostComments             TownPostComment[]

  profileEmbedding UserEmbedding?
  matchingProfile  UserMatchingProfile?
  preferenceSignal UserPreferenceSignal?

  profilePrompts         ProfilePrompt[]
  achievements           Achievement[]
  profileViewsGiven      ProfileView[]       @relation("ProfileViewViewer")
  profileViewsReceived   ProfileView[]       @relation("ProfileViewed")
  userEvents             UserEvent[]

  @@map("users")
}

// 资料向量（简介/标签等生成的哈希向量；可后续换真实 embedding + pgvector）
model UserEmbedding {
  userId    String   @id @map("user_id")
  source    String   @default("profile_hash") @map("source")
  dims      Int      @default(1024) @map("dims")
  values    Json     @map("values")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_embeddings")
}

model UserMatchingProfile {
  userId          String   @id @map("user_id")
  summaryJson     Json     @map("summary_json")
  traitsJson      Json     @map("traits_json")
  signalsJson     Json     @map("signals_json")
  embeddingJson   Json?    @map("embedding_json")
  lastRefreshedAt DateTime @default(now()) @map("last_refreshed_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_matching_profiles")
}

model UserPreferenceSignal {
  userId                   String   @id @map("user_id")
  likedTraitsJson          Json     @map("liked_traits_json")
  unlikedTraitsJson        Json     @map("unliked_traits_json")
  photoPreferenceJson      Json?    @map("photo_preference_json")
  geoPreferenceJson        Json?    @map("geo_preference_json")
  professionPreferenceJson Json?    @map("profession_preference_json")
  updatedAt                DateTime @updatedAt @map("updated_at")
  createdAt                DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preference_signals")
}

model OwnerFact {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  source    String   @default("manual")
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("owner_facts")
}

model Session {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  secondmeSessionId String?   @map("secondme_session_id")
  title             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  expiresAt         DateTime? @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model UserPreference {
  id                 String   @id @default(cuid())
  userId             String   @map("user_id")
  heartThreshold     Int      @default(80) @map("heart_threshold")
  dailyMatchTime     String?  @map("daily_match_time") // "HH:mm"
  dailyMatchTimezone String?  @map("daily_match_timezone") // "Asia/Shanghai"
  expectedGender     String?  @map("expected_gender") // male | female | any
  ageMin             Int?     @map("age_min")
  ageMax             Int?     @map("age_max")
  region             String?  @map("region")
  matchTypes         String?  @map("match_types") // JSON: ["恋人","旅游搭子",...]
  keywords           String?  @map("keywords") // 逗号分隔或 JSON
  chatPace           String?  @map("chat_pace") // "low" | "medium" | "high"
  meetPreference     String?  @map("meet_preference") // "online" | "hybrid" | "offline"
  emotionStyle       String?  @map("emotion_style") // "direct" | "slow" | "sensitive"
  activityTags       String?  @map("activity_tags") // JSON: ["一起打游戏","刷剧陪伴",...]
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])
  @@map("user_preferences")
}

model Match {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  targetUserId String   @map("target_user_id")
  status       String   @default("screening")
  starDays     Int      @default(0) @map("star_days")        // 连续聊天点亮星星天数
  starLitAt    DateTime? @map("star_lit_at")                 // 星星首次点亮时间
  chatDayCount Int      @default(0) @map("chat_day_count")   // 总聊天天数
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user       User            @relation("UserMatches", fields: [userId], references: [id], onDelete: Cascade)
  targetUser User            @relation("TargetUserMatches", fields: [targetUserId], references: [id], onDelete: Cascade)
  scores     MatchScore[]
  messages   MatchMessage[]
  feedbacks  MatchFeedback[]
  matchReads MatchRead[]     @relation("MatchReadMatch")

  @@unique([userId, targetUserId])
  @@index([userId])
  @@index([targetUserId])
  @@map("matches")
}

model MatchScore {
  id               String   @id @default(cuid())
  matchId          String   @map("match_id")
  totalScore       Int      @map("total_score")
  interestScore    Int      @map("interest_score")
  personalityScore Int      @map("personality_score")
  valuesScore      Int      @map("values_score")
  lifeStoryScore   Int      @map("life_story_score")
  futureScore      Int      @map("future_score")
  summary          String   @map("summary")
  reportJson       String?  @map("report_json")
  createdAt        DateTime @default(now()) @map("created_at")

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@map("match_scores")
}

model MatchMessage {
  id         String   @id @default(cuid())
  matchId    String   @map("match_id")
  senderType String   @map("sender_type") // "agent_self" | "agent_target" | "user_self" | "user_target"
  content    String
  createdAt  DateTime @default(now()) @map("created_at")

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([matchId, createdAt])
  @@map("match_messages")
}

model MatchFeedback {
  id             String   @id @default(cuid())
  matchId        String   @map("match_id")
  raterUserId    String   @map("rater_user_id")
  vibeScore      Int      @map("vibe_score") // 聊天感觉
  valuesScore    Int      @map("values_score") // 价值观契合度
  potentialScore Int      @map("potential_score") // 未来发展潜力
  comment        String?  @map("comment")
  createdAt      DateTime @default(now()) @map("created_at")

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  rater User  @relation(fields: [raterUserId], references: [id], onDelete: Cascade)

  @@unique([matchId, raterUserId])
  @@index([matchId])
  @@index([raterUserId])
  @@map("match_feedbacks")
}

model MatchRead {
  id         String   @id @default(cuid())
  matchId    String   @map("match_id")
  userId     String   @map("user_id")
  lastReadAt DateTime @default(now()) @map("last_read_at")

  match Match @relation("MatchReadMatch", fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation("MatchReadUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([userId])
  @@map("match_reads")
}

model UserSwipeDecision {
  id                 String   @id @default(cuid())
  viewerId           String   @map("viewer_id")
  targetUserId       String   @map("target_user_id")
  action             String   @map("action") // like | unlike
  source             String   @default("discover") @map("source")
  targetSnapshotJson Json?    @map("target_snapshot_json")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  viewer User @relation("SwipeDecisionViewer", fields: [viewerId], references: [id], onDelete: Cascade)
  target User @relation("SwipeDecisionTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([viewerId, targetUserId])
  @@index([viewerId, action, createdAt])
  @@index([targetUserId, action, createdAt])
  @@map("user_swipe_decisions")
}

model TownPost {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  title          String   @map("title")
  content        String   @map("content")
  categoriesJson String?  @map("categories_json") // JSON: ["比赛队友","创业伙伴",...]
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  author User @relation(fields: [userId], references: [id], onDelete: Cascade)

  candidateRounds TownCandidateRound[]
  conversations   TownConversation[]
  likes           TownPostLike[]
  comments        TownPostComment[]

  @@index([userId])
  @@index([createdAt])
  @@map("town_posts")
}

model TownPostLike {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  post TownPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@map("town_post_likes")
}

model TownPostComment {
  id        String   @id @default(cuid())
  postId    String   @map("post_id")
  userId    String   @map("user_id")
  content   String   @map("content")
  createdAt DateTime @default(now()) @map("created_at")

  post TownPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@map("town_post_comments")
}

model TownCandidateRound {
  id String @id @default(cuid())

  postId      String @map("post_id")
  requesterId String @map("requester_id")

  // 本轮生成的候选用户（JSON: ["userId1","userId2",...], 长度通常为 10）
  candidateUserIdsJson String? @map("candidate_user_ids_json")

  createdAt DateTime @default(now()) @map("created_at")

  post      TownPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  requester User     @relation(fields: [requesterId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([requesterId])
  @@map("town_candidate_rounds")
}

model TownConversation {
  id String @id @default(cuid())

  postId      String @map("post_id")
  requesterId String @map("requester_id")
  candidateId String @map("candidate_id")

  status        String  @default("active") @map("status") // active|closed
  openerMessage String? @map("opener_message")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  post      TownPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  requester User     @relation("TownRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  candidate User     @relation("TownCandidate", fields: [candidateId], references: [id], onDelete: Cascade)

  messages TownConversationMessage[]
  reads    TownConversationRead[]

  @@unique([postId, requesterId, candidateId])
  @@index([requesterId])
  @@index([candidateId])
  @@map("town_conversations")
}

model TownConversationMessage {
  id String @id @default(cuid())

  conversationId String @map("conversation_id")
  senderUserId   String @map("sender_user_id")
  content        String @map("content")

  createdAt DateTime @default(now()) @map("created_at")

  conversation TownConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User             @relation("TownConversationMessageSender", fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("town_conversation_messages")
}

model TownConversationRead {
  id String @id @default(cuid())

  conversationId String   @map("conversation_id")
  userId         String   @map("user_id")
  lastReadAt     DateTime @default(now()) @map("last_read_at")

  conversation TownConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User             @relation("TownConversationReadsUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("town_conversation_reads")
}

model ProfilePrompt {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  promptKey String   @map("prompt_key")     // e.g. "favorite_movie", "dealbreaker", "weekend_vibe"
  answer    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, promptKey])
  @@map("profile_prompts")
}

model Achievement {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  badgeKey   String   @map("badge_key")      // "first_match", "chat_7_days", "ice_breaker", etc.
  unlockedAt DateTime @default(now()) @map("unlocked_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeKey])
  @@map("achievements")
}

model ProfileView {
  id        String   @id @default(cuid())
  viewerId  String   @map("viewer_id")
  viewedId  String   @map("viewed_id")
  createdAt DateTime @default(now()) @map("created_at")
  viewer    User     @relation("ProfileViewViewer", fields: [viewerId], references: [id], onDelete: Cascade)
  viewed    User     @relation("ProfileViewed", fields: [viewedId], references: [id], onDelete: Cascade)

  @@index([viewedId, createdAt])
  @@index([viewerId])
  @@map("profile_views")
}

model UserEvent {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  eventType String   @map("event_type")     // "page_view", "swipe", "match", "chat_send", etc.
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([userId, createdAt])
  @@map("user_events")
}
