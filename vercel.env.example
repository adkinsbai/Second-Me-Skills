# 在 Vercel 项目：Settings → Environment Variables 中粘贴（Production + Preview 按需复制）
# 值从本机 .env.local 对应复制；勿提交 .env 到 Git

# 必填：Neon/Postgres 连接串（可带 ?sslmode=require）
DATABASE_URL=

# SecondMe OAuth / API（与线上一致）
SECONDME_CLIENT_ID=
SECONDME_CLIENT_SECRET=
# 生产环境必须设为： https://<你的 Vercel 域名>/api/auth/callback
SECONDME_REDIRECT_URI=
SECONDME_OAUTH_URL=
SECONDME_TOKEN_ENDPOINT=
SECONDME_REFRESH_ENDPOINT=
SECONDME_API_BASE_URL=

# 构建时 Vercel 会设 VERCEL=1，scripts/prebuild-dbpush.mjs 会对 DATABASE_URL 执行 prisma db push
# 若需本地模拟：FORCE_DB_PUSH=1
